{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "ClearFlow Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.2.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "ClearFlow ISO 20022 — Real-time payment pipeline command centre",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "SLO Dashboard",
      "url": "/d/clearflow-slo",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["clearflow", "payments"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "ClearFlow — Command Center",
  "uid": "clearflow-cmd",
  "version": 1,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Payment Rate",
      "description": "Payments initiated per minute (1-minute rolling rate)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(sum(clearflow_payments_total)[1m]) * 60",
          "legendFormat": "payments/min",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "payments/min",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Settlement Rate %",
      "description": "Percentage of initiated payments that reach settlement (5-minute window)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_settlements_total[5m])) / clamp_min(sum(rate(clearflow_payments_total[5m])), 0.001) * 100",
          "legendFormat": "settlement %",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Fraud Block Rate %",
      "description": "AML-blocked payments as a percentage of all AML decisions (5-minute window)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_aml_hit_total[5m])) / clamp_min(sum(rate(clearflow_aml_hit_total[5m])) + sum(rate(clearflow_aml_clear_total[5m])), 1) * 100",
          "legendFormat": "fraud block %",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Routing Failure %",
      "description": "Routing failures as a percentage of all routing decisions (5-minute window)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_routing_failed_total[5m])) / clamp_min(sum(rate(clearflow_routing_routed_total[5m])) + sum(rate(clearflow_routing_failed_total[5m])), 1) * 100",
          "legendFormat": "routing failure %",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Gateway P99 Latency",
      "description": "99th-percentile HTTP response latency for the gateway service (5-minute window)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99 ms",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "In-Flight Payments",
      "description": "Current number of payments being processed by the gateway",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "clearflow_gateway_inflight",
          "legendFormat": "in-flight",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 800 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Payment Throughput (TPS)",
      "description": "Initiated vs settled payment throughput — transactions per second over a 1-minute rolling window",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_payments_total[1m]))",
          "legendFormat": "initiated"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_settlements_total[1m]))",
          "legendFormat": "settled"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "initiated" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5470c6" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "settled" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3fb950" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          }
        ]
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Pipeline Error Rate",
      "description": "Stacked area of validation rejections, AML blocks, and routing failures per second",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_validation_rejected_total[1m]))",
          "legendFormat": "validation rejected"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_aml_hit_total[1m]))",
          "legendFormat": "aml blocked"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_routing_failed_total[1m]))",
          "legendFormat": "routing failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 40,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "validation rejected" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#f0883e" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "aml blocked" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e05252" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "routing failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#8b0000" } }
            ]
          }
        ]
      }
    },

    {
      "id": 9,
      "type": "bargauge",
      "title": "Pipeline Funnel (5m rate)",
      "description": "Volume at each pipeline stage — highlights where payments drop off",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_payments_total[5m]))",
          "legendFormat": "initiated",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_fraud_scored_total[5m]))",
          "legendFormat": "fraud-scored",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_validation_accepted_total[5m]))",
          "legendFormat": "validated",
          "instant": true
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_aml_clear_total[5m]))",
          "legendFormat": "aml-cleared",
          "instant": true
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_routing_routed_total[5m]))",
          "legendFormat": "routed",
          "instant": true
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_settlements_total[5m]))",
          "legendFormat": "settled",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": { "mode": "continuous-BlYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "type": "piechart",
      "title": "Fraud Risk Band Distribution",
      "description": "Share of payments by risk band over 5-minute window",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_payments_total{riskBand=~\".+\"}[5m])) by (riskBand)",
          "legendFormat": "{{riskBand}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["percent", "value"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CRITICAL" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#f85149" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "HIGH" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#f0883e" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "MEDIUM" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d29922" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "LOW" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3fb950" } }
            ]
          }
        ]
      }
    },

    {
      "id": 11,
      "type": "piechart",
      "title": "Currency Distribution",
      "description": "Payment volume share per currency over 5-minute window",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(clearflow_payments_total[5m])) by (currency)",
          "legendFormat": "{{currency}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["percent", "value"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Latency Percentiles",
      "description": "p50 / p95 / p99 response latency in milliseconds for gateway, fraud-scoring, and settlement services",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])) by (le)) * 1000",
          "legendFormat": "gateway p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])) by (le)) * 1000",
          "legendFormat": "gateway p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"gateway\"}[5m])) by (le)) * 1000",
          "legendFormat": "gateway p99"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"fraud-scoring\"}[5m])) by (le)) * 1000",
          "legendFormat": "fraud-scoring p50"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"fraud-scoring\"}[5m])) by (le)) * 1000",
          "legendFormat": "fraud-scoring p95"
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"fraud-scoring\"}[5m])) by (le)) * 1000",
          "legendFormat": "fraud-scoring p99"
        },
        {
          "refId": "G",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"settlement\"}[5m])) by (le)) * 1000",
          "legendFormat": "settlement p50"
        },
        {
          "refId": "H",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"settlement\"}[5m])) by (le)) * 1000",
          "legendFormat": "settlement p95"
        },
        {
          "refId": "I",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"settlement\"}[5m])) by (le)) * 1000",
          "legendFormat": "settlement p99"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*p50$" },
            "properties": [
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.lineStyle", "value": { "fill": "solid" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*p95$" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [6, 3] } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*p99$" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [2, 2] } }
            ]
          }
        ]
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "JVM Heap Usage %",
      "description": "Heap utilisation per application — alert threshold at 80 %",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / clamp_min(jvm_memory_max_bytes{area=\"heap\"}, 1) * 100",
          "legendFormat": "{{application}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["last", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(242, 73, 92, 0.15)", "value": 80 }
            ]
          }
        },
        "overrides": []
      }
    }

  ]
