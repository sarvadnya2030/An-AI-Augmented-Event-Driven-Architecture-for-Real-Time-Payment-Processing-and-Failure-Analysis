{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ClearFlow payment pipeline — operations overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Fraud Dashboard", "url": "/d/clearflow-fraud", "type": "link" }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Payments Submitted (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(clearflow_payments_total{service=\"gateway\"}[5m])",
          "legendFormat": "submitted"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }
      ]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Fraud Scored (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(clearflow_payments_total{service=\"fraud-scoring\"}[5m])",
          "legendFormat": "scored"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current Fraud Score",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "clearflow_fraud_score_current",
          "legendFormat": "score"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit",
        "color": { "mode": "thresholds" }, "thresholds": { "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.8 }
        ]}
      }}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\",job=~\"clearflow.*\"}[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 0.1 }
      ]}}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Payment Throughput by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(clearflow_payments_total[1m])",
          "legendFormat": "{{service}} / {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Processing Latency p99 by Stage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(clearflow_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{service}} / {{stage}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Payments by Risk Band",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(clearflow_payments_total{service=\"fraud-scoring\"}[5m])",
          "legendFormat": "{{riskBand}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" }}] },
          { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" }}] },
          { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" }}] },
          { "matcher": { "id": "byName", "options": "LOW" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" }}] }
        ]
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM Heap Usage by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=~\"clearflow.*\"}",
          "legendFormat": "{{job}} heap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 1 } } }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["clearflow", "payments", "operations"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ClearFlow — Payment Operations",
  "uid": "clearflow-main",
  "version": 1
}
